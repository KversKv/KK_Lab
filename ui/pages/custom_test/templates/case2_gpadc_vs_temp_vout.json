[
  {
    "node_type": "LoopList",
    "uid": "tpl2-loop-temp",
    "params": {
      "var_name": "temp",
      "values": "-20, 0, 25, 60, 85"
    },
    "children": [
      {
        "node_type": "ChamberSetTemp",
        "uid": "tpl2-set-temp",
        "params": {
          "temperature": "${temp}",
          "wait_stable": true,
          "stable_time": 120.0,
          "tolerance": 1.0
        }
      },
      {
        "node_type": "LoopRange",
        "uid": "tpl2-loop-vout",
        "params": {
          "var_name": "vout",
          "start": 1.5,
          "stop": 3.8,
          "step": 0.1
        },
        "children": [
          {
            "node_type": "N6705CSetVoltage",
            "uid": "tpl2-set-voltage",
            "params": {
              "channel": 1,
              "voltage": "${vout}",
              "current_limit": "1.0",
              "output_on": true
            }
          },
          {
            "node_type": "Delay",
            "uid": "tpl2-delay",
            "params": {
              "seconds": 2.0
            }
          },
          {
            "node_type": "N6705CMeasure",
            "uid": "tpl2-measure-v",
            "params": {
              "channel": 2,
              "measure_type": "voltage",
              "result_var": "gpadc_voltage"
            }
          },
          {
            "node_type": "RecordDataPoint",
            "uid": "tpl2-record",
            "params": {
              "fields": "temp=${temp}, vout=${vout}, gpadc_voltage=${gpadc_voltage}"
            }
          }
        ]
      }
    ]
  },
  {
    "node_type": "ExportResult",
    "uid": "tpl2-export",
    "params": {
      "format": "csv",
      "filename": "gpadc_vs_temp_vout",
      "output_dir": ""
    }
  }
]
